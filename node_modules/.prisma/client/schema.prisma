generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CollegeType {
  GOVT
  PRIVATE
  DEEMED
}

enum CutoffCategory {
  GENERAL
  OBC
  SC
  ST
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model College {
  id            Int         @id @default(autoincrement())
  name          String
  city          String
  state         String
  type          CollegeType
  streams       String[]
  nirf_rank     Int?
  established   Int
  accreditation String
  website       String
  createdAt     DateTime    @default(now())

  courseFees     CourseFee[]
  placements     PlacementStat[]
  cutoffs        AdmissionCutoff[]
  reviews        Review[]
  shortlistItems ShortlistItem[]

  @@index([name, city])
}

model CourseFee {
  id         Int    @id @default(autoincrement())
  college_id Int
  course     String
  degree     String
  annual_fee Int

  college College @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@unique([college_id, course, degree])
  @@index([college_id])
}

model PlacementStat {
  id             Int      @id @default(autoincrement())
  college_id     Int
  year           Int
  avg_pkg        Float
  max_pkg        Float
  placement_pct  Float
  top_recruiters String[]

  college College @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@unique([college_id, year])
  @@index([college_id])
}

model AdmissionCutoff {
  id           Int            @id @default(autoincrement())
  college_id   Int
  exam         String
  year         Int
  category     CutoffCategory
  cutoff_value Float

  college College @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@unique([college_id, exam, year, category])
  @@index([college_id])
}

model Review {
  id               Int          @id @default(autoincrement())
  college_id       Int
  author_name      String
  batch_year       Int
  stream           String
  rating_overall   Float
  rating_placement Float
  rating_faculty   Float
  rating_infra     Float
  body             String
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  college College @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@index([college_id])
}

model ShortlistSession {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ShortlistItem[]
}

model ShortlistItem {
  id         Int      @id @default(autoincrement())
  session_id String
  college_id Int
  createdAt  DateTime @default(now())

  session ShortlistSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  college College          @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@unique([session_id, college_id])
  @@index([session_id])
  @@index([college_id])
}
