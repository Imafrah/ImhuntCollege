generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CollegeType {
  GOVT
  PRIVATE
  DEEMED
}

enum CutoffCategory {
  GENERAL
  OBC
  SC
  ST
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model College {
  id            Int               @id @default(autoincrement())
  name          String
  city          String
  state         String
  type          CollegeType
  streams       String[]
  nirf_rank     Int?
  established   Int
  accreditation String
  website       String
  createdAt     DateTime          @default(now())

  courseFees    CourseFee[]
  placements    PlacementStat[]
  cutoffs       AdmissionCutoff[]
  reviews       Review[]

  // PostgreSQL full-text search: add a generated tsvector column/index in a migration, e.g. to_tsvector('english', coalesce(name, '') || ' ' || coalesce(city, '')).
  @@index([name, city])
}

model CourseFee {
  id         Int     @id @default(autoincrement())
  college_id Int
  course     String
  degree     String
  annual_fee Int

  college    College @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@index([college_id])
}

model PlacementStat {
  id             Int      @id @default(autoincrement())
  college_id     Int
  year           Int
  avg_pkg        Float
  max_pkg        Float
  placement_pct  Float
  top_recruiters String[]

  college        College  @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@index([college_id])
}

model AdmissionCutoff {
  id           Int            @id @default(autoincrement())
  college_id   Int
  exam         String
  year         Int
  category     CutoffCategory
  cutoff_value Float

  college      College        @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@index([college_id])
}

model Review {
  id               Int          @id @default(autoincrement())
  college_id       Int
  author_name      String
  batch_year       Int
  stream           String
  rating_overall   Float
  rating_placement Float
  rating_faculty   Float
  rating_infra     Float
  body             String
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  college          College      @relation(fields: [college_id], references: [id], onDelete: Cascade)

  @@index([college_id])
}
